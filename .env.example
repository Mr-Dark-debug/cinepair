# ============================================================
# CinePair Environment Configuration
# ============================================================

# ─── Server ──────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ─── CORS (comma-separated origins) ─────────────────────────
CORS_ORIGINS=http://localhost:5173
ALLOW_ELECTRON_ORIGIN=false

# ─── JWT (CHANGE IN PRODUCTION!) ─────────────────────────────
JWT_SECRET=cinepair-dev-secret-change-me-in-production
JWT_EXPIRES_IN=24h

# ─── Room Settings ───────────────────────────────────────────
ROOM_CODE_LENGTH=8
ROOM_EXPIRY_HOURS=24
MAX_USERS_PER_ROOM=2
RECONNECT_GRACE_SECONDS=90

# ─── ICE / TURN Servers ─────────────────────────────────────
# STUN servers (comma-separated)
PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN server (optional — generates ephemeral credentials via HMAC-SHA1)
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your-turn-static-username
# TURN_CREDENTIAL=your-turn-shared-secret
# TURN_TTL_SECONDS=3600

# ─── Observability ───────────────────────────────────────────
ENABLE_METRICS=false
# METRICS_TOKEN=your-metrics-bearer-token
LOG_LEVEL=info

# ─── Client (Vite env vars) ─────────────────────────────────
VITE_SIGNALING_URL=http://localhost:3001
